# Polyrus 글로벌 계정 (env식) — 기획안 6.3
# 이 파일은 '선언'만 합니다. 실제 비밀값은 OS 키체인에서 해석됩니다.
# 평문 비밀을 여기 직접 넣지 마세요(폴백일 때만, 권한 600 + .gitignore 필수).
#
# 형식: POLYRUS_<SERVICE>_<IDENTITY>_<FIELD>=<backend>:<locator>
#   backend = keychain | env | dotenv
#
# 사용법: cp account.env.example ~/.polyrus/account.env  (그리고 키체인에 실제 값 저장)

# Gmail 작업 계정 — 토큰은 키체인 항목 'polyrus/gmail/work'에서 해석
POLYRUS_GMAIL_WORK_EMAIL=keychain:polyrus/gmail/work/email
POLYRUS_GMAIL_WORK_TOKEN=keychain:polyrus/gmail/work/token

# GitHub 개인 — 토큰은 환경변수에서
POLYRUS_GITHUB_PERSONAL_TOKEN=env:GITHUB_TOKEN

# 모델 API 키 — 모델 프롬프트엔 절대 안 들어가고, 도구 경계에서만 주입
POLYRUS_ANTHROPIC_DEFAULT_API_KEY=keychain:polyrus/anthropic/key

# 텔레그램 알림 + 원탭 승인/거부 (6.4 확인 트레이 / 6.1 게이트) — away 유저 폰 채널.
# 지금은 env 직접 읽기(도구 경계). 봇 토큰은 @BotFather, chat_id는 봇에 말 건 뒤
#   https://api.telegram.org/bot<TOKEN>/getUpdates 의 chat.id 로 확인.
#   export POLYRUS_TELEGRAM_TOKEN=...   export POLYRUS_TELEGRAM_CHAT_ID=...
POLYRUS_TELEGRAM_DEFAULT_TOKEN=env:POLYRUS_TELEGRAM_TOKEN
POLYRUS_TELEGRAM_DEFAULT_CHAT_ID=env:POLYRUS_TELEGRAM_CHAT_ID
